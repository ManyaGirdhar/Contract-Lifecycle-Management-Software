 "font_size": 14,
 "html": "<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <title>{{ doc.name }} Agreement</title>\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 40px;\n            background-color: #f8f9fa;\n            color: #333;\n            line-height: 1.6;\n        }\n        h1 {\n            text-align: center;\n            color: #2c3e50;\n            border-bottom: 3px solid #2980b9;\n            padding-bottom: 10px;\n        }\n        .section-title {\n            font-size: 18px;\n            font-weight: bold;\n            color: #2980b9;\n            margin-top: 30px;\n            padding-bottom: 5px;\n            border-bottom: 2px solid #ddd;\n        }\n        table {\n            width: 100%;\n            border-collapse: collapse;\n            margin-top: 10px;\n            background: white;\n            box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.1);\n            border-radius: 5px;\n            overflow: hidden;\n        }\n        th, td {\n            padding: 12px;\n            border: 1px solid #ddd;\n            text-align: left;\n        }\n        th {\n            background: #2980b9;\n            color: white;\n        }\n        tr:nth-child(even) {\n            background: #f2f2f2;\n        }\n        .signature-block {\n            margin-top: 50px;\n            text-align: center;\n        }\n        .signature-block table {\n            width: 70%;\n            margin: 0 auto;\n            border: none;\n        }\n        .signature-block th {\n            text-align: center;\n            background: none;\n            color: #333;\n        }\n        .signature-line {\n            border-bottom: 1px solid #333;\n            width: 200px;\n            display: inline-block;\n            margin-top: 10px;\n        }\n        .footer {\n            margin-top: 30px;\n            font-size: 14px;\n            color: #777;\n            text-align: center;\n        }\n    </style>\n</head>\n<body>\n\n<h1>{{ contract_type }} Agreement</h1>\n<p><strong>Status:</strong> {{ doc.status }}</p>\n<p><strong>Effective Date:</strong> {{ doc.contract_effective_date }}</p>\n<p><strong>Contract End Date:</strong> {{ doc.contract_end_date }}</p>\n\n<div class=\"section-title\">1. Initiator Details</div>\n<table>\n    <tr><th>Requester Name</th><td>{{ doc.requester_name }}</td></tr>\n    <tr><th>Department</th><td>{{ doc.requester_department }}</td></tr>\n</table>\n\n<div class=\"section-title\">2. Other Party Information</div>\n<table>\n    <tr><th>Counterparty Name</th><td>{{ doc.counterparty_name }}</td></tr>\n    <tr><th>Email</th><td>{{ doc.counterparty_email }}</td></tr>\n</table>\n\n<div class=\"section-title\">3. Employment Duration</div>\n<table>\n    <tr><th>Contract Term</th><td>{{ doc.contract_term }}</td></tr>\n    <tr><th>Duration (months)</th><td>{{ doc.contract_duration }}</td></tr>\n    <tr><th>Termination Notice Period (days)</th><td>{{ doc.termination_notice_period }}</td></tr>\n</table>\n\n<div class=\"section-title\">4. Extension & Renewal Terms</div>\n<table>\n    <tr><th>Is Contract Renewable?</th><td>{{ doc.is_contract_renewable }}</td></tr>\n</table>\n\n<div class=\"section-title\">5. Compensation & Taxation</div>\n<table>\n    <tr><th>Amount to Receive</th><td>\u20b9{{ doc.amount_to_receive }}</td></tr>\n    <tr><th>Applicable Tax Rate</th><td>{{ doc.tax }}%</td></tr>\n    <tr><th>Gross Payable Amount</th><td>\u20b9{{ doc.total_amount }}</td></tr>\n</table>\n\n<div class=\"section-title\">6. Agreement Terms & Conditions</div>\n<p>{{ doc.content }}</p>\n\n<div class=\"signature-block\">\n    <table>\n        <tr>\n            <th>Requester Signature</th>\n            <td><span class=\"signature-line\"></span></td>\n        </tr>\n        <tr>\n            <th>Counterparty Signature</th>\n            <td><span class=\"signature-line\"></span></td>\n        </tr>\n        <tr>\n            <th>Date</th>\n            <td>{{ doc.contract_effective_date }}</td>\n        </tr>\n    </table>\n</div>\n\n<div class=\"footer\">\n    <p>This agreement is confidential and legally binding.</p>\n</div>\n\n</body>\n</html>\n",
